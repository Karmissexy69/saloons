# Copy this file to `.env` and fill real values.
# Do not commit real secrets.

# Spring datasource
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/salonpos
SPRING_DATASOURCE_USERNAME=myuser
SPRING_DATASOURCE_PASSWORD=mypassword

# App JWT
APP_JWT_SECRET=change-this-secret-change-this-secret-2026
APP_JWT_EXPIRATION_SECONDS=3600
APP_ATTENDANCE_TERMINAL_ENABLED=true
APP_ATTENDANCE_TERMINAL_USERNAME=attendance_terminal
APP_ATTENDANCE_TERMINAL_PASSWORD=change-this-terminal-password

# Biometric app config
APP_BIOMETRIC_AWS_REGION=ap-southeast-1
APP_BIOMETRIC_COLLECTION_ID=salonpos-staff-faces
APP_BIOMETRIC_S3_BUCKET=salonpos-biometric-private
APP_BIOMETRIC_FACE_MATCH_THRESHOLD=80
APP_BIOMETRIC_TOKEN_TTL_MINUTES=10
APP_BIOMETRIC_PROBE_PURGE_DAY_OF_MONTH=7
APP_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AWS credentials (for SDK default credential provider chain)
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=ap-southeast-1
